<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Chat</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <h3>New Chat</h3>
    <form action="/chats" method="POST" class="chat">
      <p>
        <label>From: <input type="text" name="from" required /></label>
      </p>
      <p>
        <label>To: <input type="text" name="to" required /></label>
      </p>
      <div class="msg">
        <label
          >Message: <input type="text" name="msg" required style="width: 90%"
        /></label>
      </div>
      <br />
      <button type="submit">Send</button>
    </form>
    <p style="text-align: center"><a href="/chats">Back to Chats</a></p>
  </body>
</html>
